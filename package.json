{
  "name": "spyglass",
  "private": false,
  "version": "0.12.0",
  "skateboardVersion": "3.5.0",
  "type": "module",
  "workspaces": [
    "backend"
  ],
  "scripts": {
    "start": "npm run front & npm run server",
    "front": "vite --force --mode development",
    "server": "npm run --workspace=backend start",
    "build": "vite build --mode production",
    "prod": "vite build --mode production",
    "install-all": "npm install && npm install --workspace=backend",
    "test": "vitest run",
    "test:watch": "vitest",
    "verify:ui": "node scripts/verify-ui-version.mjs"
  },
  "dependencies": {
    "@stevederico/skateboard-ui": "3.8.0",
    "fflate": "^0.8.2",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "react-router": "7.15.0",
    "sonner": "^2.0.7"
  },
  "devDependencies": {
    "@tailwindcss/vite": "4.3.0",
    "@vitejs/plugin-react-swc": "4.3.1",
    "jsdom": "^29.0.0",
    "tailwindcss": "4.3.0",
    "vite": "8.0.13",
    "vitest": "^4.1.0"
  }
}
