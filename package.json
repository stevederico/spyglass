{
  "name": "spyglass",
  "private": false,
  "version": "0.11.0",
  "skateboardVersion": "2.28.0",
  "type": "module",
  "workspaces": [
    "backend"
  ],
  "scripts": {
    "start": "npm run front & npm run server",
    "front": "vite --force --mode development",
    "server": "npm run --workspace=backend start",
    "build": "vite build --mode production",
    "prod": "vite build --mode production",
    "install-all": "npm install && npm install --workspace=backend",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/modifiers": "^9.0.0",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@stevederico/skateboard-ui": "2.20.0",
    "@tanstack/react-table": "^8.21.3",
    "fflate": "^0.8.2",
    "lucide-react": "^0.563.0",
    "next-themes": "^0.4.6",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-router-dom": "^7.9.4",
    "recharts": "^3.7.0",
    "sonner": "^2.0.7",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react-swc": "^4.1.0",
    "tailwindcss": "^4.1.14",
    "jsdom": "^29.0.0",
    "vite": "^7.1.10",
    "vitest": "^4.1.0"
  }
}
