{
  "name": "spyglass",
  "private": false,
  "version": "0.9.3",
  "skateboardVersion": "2.12.0",
  "type": "module",
  "workspaces": [
    "backend"
  ],
  "scripts": {
    "start": "npm run front & npm run server",
    "front": "vite --force --mode development",
    "server": "npm run --workspace=backend start",
    "build": "vite build --mode production",
    "prod": "vite build --mode production",
    "install-all": "npm install && npm install --workspace=backend",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@stevederico/skateboard-ui": "2.9.8",
"fflate": "^0.8.2",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-router-dom": "^7.9.4",
    "sonner": "^2.0.7"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react-swc": "^4.1.0",
    "tailwindcss": "^4.1.14",
    "jsdom": "^29.0.0",
    "vite": "^7.1.10",
    "vitest": "^4.1.0"
  }
}
